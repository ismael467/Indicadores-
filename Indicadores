<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cripto Precio</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --card: #12121a;
    --border: #1e1e2e;
    --yellow: #f5c842;
    --green: #3dffa0;
    --red: #ff4d6d;
    --text: #e8e8f0;
    --muted: #555570;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .container {
    width: 100%;
    max-width: 420px;
  }

  h1 {
    font-size: 13px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 32px;
    font-family: 'Space Mono', monospace;
  }

  h1 span {
    color: var(--yellow);
  }

  .search-box {
    display: flex;
    gap: 10px;
    margin-bottom: 24px;
  }

  input {
    flex: 1;
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 14px 18px;
    font-family: 'Space Mono', monospace;
    font-size: 16px;
    text-transform: uppercase;
    outline: none;
    border-radius: 4px;
    transition: border-color 0.2s;
    letter-spacing: 2px;
  }

  input:focus {
    border-color: var(--yellow);
  }

  input::placeholder {
    color: var(--muted);
    font-size: 13px;
    letter-spacing: 1px;
  }

  button {
    background: var(--yellow);
    color: #0a0a0f;
    border: none;
    padding: 14px 20px;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 13px;
    cursor: pointer;
    border-radius: 4px;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  button:hover { opacity: 0.85; }
  button:disabled { opacity: 0.4; cursor: not-allowed; }

  .chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .chip {
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 6px 14px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    cursor: pointer;
    border-radius: 20px;
    transition: all 0.2s;
    letter-spacing: 1px;
  }

  .chip:hover {
    border-color: var(--yellow);
    color: var(--yellow);
  }

  .result {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 28px;
    display: none;
    animation: fadeIn 0.3s ease;
  }

  .result.visible { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .coin-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .coin-name {
    font-size: 22px;
    font-weight: 800;
    color: var(--text);
  }

  .coin-symbol {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 2px;
    margin-top: 4px;
  }

  .coin-img {
    width: 48px;
    height: 48px;
    border-radius: 50%;
  }

  .price-big {
    font-family: 'Space Mono', monospace;
    font-size: 32px;
    font-weight: 700;
    color: var(--yellow);
    margin-bottom: 8px;
  }

  .change {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    margin-bottom: 24px;
  }

  .change.up { color: var(--green); }
  .change.down { color: var(--red); }

  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .stat {
    background: var(--bg);
    border-radius: 6px;
    padding: 14px;
  }

  .stat-label {
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 6px;
    font-family: 'Space Mono', monospace;
  }

  .stat-value {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--text);
    font-weight: 700;
  }

  .error {
    background: rgba(255,77,109,0.1);
    border: 1px solid rgba(255,77,109,0.3);
    color: var(--red);
    padding: 16px 20px;
    border-radius: 6px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    display: none;
  }

  .error.visible { display: block; }

  .loading {
    text-align: center;
    padding: 40px;
    color: var(--muted);
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    display: none;
    letter-spacing: 2px;
  }

  .loading.visible { display: block; }

  .dot {
    animation: blink 1s infinite;
  }
  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes blink {
    0%, 80%, 100% { opacity: 0; }
    40% { opacity: 1; }
  }

  .updated {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    margin-top: 16px;
    letter-spacing: 1px;
  }
</style>
</head>
<body>

<div class="container">
  <h1>◈ Cripto <span>Precio</span></h1>

  <div class="search-box">
    <input type="text" id="ticker" placeholder="BTC, ETH, SOL..." maxlength="10" />
    <button id="btn" onclick="buscar()">BUSCAR</button>
  </div>

  <div class="chips">
    <div class="chip" onclick="buscarDirecto('bitcoin')">BTC</div>
    <div class="chip" onclick="buscarDirecto('ethereum')">ETH</div>
    <div class="chip" onclick="buscarDirecto('solana')">SOL</div>
    <div class="chip" onclick="buscarDirecto('cardano')">ADA</div>
    <div class="chip" onclick="buscarDirecto('ripple')">XRP</div>
  </div>

  <div class="loading" id="loading">
    BUSCANDO<span class="dot">.</span><span class="dot">.</span><span class="dot">.</span>
  </div>

  <div class="error" id="error">⚠ Cripto no encontrada. Prueba con BTC, ETH, SOL...</div>

  <div class="result" id="result">
    <div class="coin-header">
      <div>
        <div class="coin-name" id="coin-name">—</div>
        <div class="coin-symbol" id="coin-symbol">—</div>
      </div>
      <img class="coin-img" id="coin-img" src="" alt="" onerror="this.style.display='none'" />
    </div>
    <div class="price-big" id="price">—</div>
    <div class="change" id="change">—</div>
    <div class="stats">
      <div class="stat">
        <div class="stat-label">Máx 24h</div>
        <div class="stat-value" id="high">—</div>
      </div>
      <div class="stat">
        <div class="stat-label">Mín 24h</div>
        <div class="stat-value" id="low">—</div>
      </div>
      <div class="stat">
        <div class="stat-label">Cap. Mercado</div>
        <div class="stat-value" id="mcap">—</div>
      </div>
      <div class="stat">
        <div class="stat-label">Volumen 24h</div>
        <div class="stat-value" id="vol">—</div>
      </div>
    </div>
    <div class="updated" id="updated"></div>
  </div>
</div>

<script>
const tickerToId = {
  'BTC': 'bitcoin', 'ETH': 'ethereum', 'SOL': 'solana',
  'ADA': 'cardano', 'XRP': 'ripple', 'BNB': 'binancecoin',
  'DOGE': 'dogecoin', 'DOT': 'polkadot', 'MATIC': 'matic-network',
  'LINK': 'chainlink', 'AVAX': 'avalanche-2', 'SHIB': 'shiba-inu',
  'LTC': 'litecoin', 'UNI': 'uniswap', 'ATOM': 'cosmos',
  'TRX': 'tron', 'TON': 'the-open-network', 'SUI': 'sui',
  'APT': 'aptos', 'NEAR': 'near'
};

function formatNum(n) {
  if (n >= 1e9) return '$' + (n/1e9).toFixed(2) + 'B';
  if (n >= 1e6) return '$' + (n/1e6).toFixed(2) + 'M';
  if (n >= 1000) return '$' + n.toLocaleString('es-ES', {maximumFractionDigits: 0});
  if (n >= 1) return '$' + n.toFixed(2);
  return '$' + n.toFixed(6);
}

function show(id) {
  document.getElementById('loading').classList.remove('visible');
  document.getElementById('error').classList.remove('visible');
  document.getElementById('result').classList.remove('visible');
  document.getElementById(id).classList.add('visible');
}

async function buscarDirecto(coinId) {
  await fetchCoin(coinId);
}

async function buscar() {
  const raw = document.getElementById('ticker').value.trim().toUpperCase();
  if (!raw) return;
  const coinId = tickerToId[raw] || raw.toLowerCase();
  await fetchCoin(coinId);
}

async function fetchCoin(coinId) {
  document.getElementById('btn').disabled = true;
  show('loading');

  try {
    const url = `https://api.coingecko.com/api/v3/coins/${coinId}?localization=false&tickers=false&community_data=false&developer_data=false`;
    const res = await fetch(url);
    if (!res.ok) throw new Error('not found');
    const d = await res.json();

    const price = d.market_data.current_price.usd;
    const change = d.market_data.price_change_percentage_24h;
    const high = d.market_data.high_24h.usd;
    const low = d.market_data.low_24h.usd;
    const mcap = d.market_data.market_cap.usd;
    const vol = d.market_data.total_volume.usd;

    document.getElementById('coin-name').textContent = d.name;
    document.getElementById('coin-symbol').textContent = d.symbol.toUpperCase();
    document.getElementById('coin-img').src = d.image.small;
    document.getElementById('price').textContent = formatNum(price);

    const changeEl = document.getElementById('change');
    const sign = change >= 0 ? '+' : '';
    changeEl.textContent = `${sign}${change.toFixed(2)}% últimas 24h`;
    changeEl.className = 'change ' + (change >= 0 ? 'up' : 'down');

    document.getElementById('high').textContent = formatNum(high);
    document.getElementById('low').textContent = formatNum(low);
    document.getElementById('mcap').textContent = formatNum(mcap);
    document.getElementById('vol').textContent = formatNum(vol);

    const now = new Date();
    document.getElementById('updated').textContent = `Actualizado: ${now.toLocaleTimeString('es-ES')}`;

    show('result');
  } catch {
    show('error');
  }

  document.getElementById('btn').disabled = false;
}

document.getElementById('ticker').addEventListener('keydown', e => {
  if (e.key === 'Enter') buscar();
});
</script>
</body>
</html>
